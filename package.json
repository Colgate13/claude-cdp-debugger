{
  "name": "claude-cdp-debugger",
  "version": "0.2.0",
  "description": "A Claude Code plugin that lets the agent live-debug any Node.js service via Chrome DevTools Protocol — discovers .vscode/launch.json automatically, sets breakpoints, captures pauses, inspects state, and reports back conversationally.",
  "keywords": [
    "claude-code",
    "claude-plugin",
    "claude-skill",
    "debugger",
    "chrome-devtools-protocol",
    "cdp",
    "nodejs",
    "inspector",
    "agent"
  ],
  "license": "MIT",
  "author": "Gabriel Barros F. Sa <gabreilbarros13@gmail.com>",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "cdp": "bin/cdp"
  },
  "files": [
    "README.md",
    "INSTALL.md",
    "TROUBLESHOOTING.md",
    "LICENSE",
    "dist",
    "bin/cdp",
    "bin/install.sh",
    "skills",
    ".claude-plugin"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "test:unit": "node --test --import tsx 'test/**/*.test.ts'",
    "test:integration": "npm run build && node --test --test-timeout=60000 --import tsx 'test-integration/**/*.test.ts'",
    "test:all": "npm run test:unit && npm run test:integration",
    "coverage": "c8 npm run test:unit",
    "duplication": "jscpd",
    "deadcode": "knip",
    "docs": "typedoc",
    "docs:coverage": "node scripts/doc-coverage.mjs",
    "audit": "npm audit --omit=dev --audit-level=high",
    "bundle:size": "node scripts/bundle-size.mjs",
    "quality": "node scripts/quality-gate.mjs",
    "doctor": "node dist/cli.js doctor",
    "prepack": "npm run build"
  },
  "dependencies": {
    "chrome-remote-interface": "0.33.3",
    "source-map": "0.7.4"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^22.10.5",
    "c8": "^11.0.0",
    "devtools-protocol": "0.0.1173815",
    "esbuild": "^0.27.7",
    "eslint": "^9.18.0",
    "jscpd": "^4.0.9",
    "knip": "^6.12.1",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
