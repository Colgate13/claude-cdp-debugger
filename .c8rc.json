{
  "all": true,
  "include": [
    "src/lib/**/*.ts"
  ],
  "exclude": [
    "src/bin/**",
    "**/*.d.ts",
    "**/types.ts"
  ],
  "extension": [".ts"],
  "reporter": ["text", "lcov", "html", "json-summary"],
  "report-dir": "quality-reports/coverage",
  "check-coverage": true,
  "lines": 60,
  "statements": 60,
  "branches": 50,
  "functions": 65,
  "skip-full": false
}
